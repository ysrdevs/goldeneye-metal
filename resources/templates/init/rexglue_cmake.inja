    set(REXGLUE_HOST_TARGET {{ cmake_var("PROJECT_NAME") }})
endif()

# Include entrypoint generated code if codegen has been run.
if(EXISTS "{{ cmake_var("CMAKE_CURRENT_SOURCE_DIR") }}/{{ entrypoint_out_dir }}/sources.cmake")
    include({{ entrypoint_out_dir }}/sources.cmake)
    set(REXGLUE_ENTRYPOINT_GENERATED_SOURCES {{ cmake_var("GENERATED_SOURCES") }})
    set(REXGLUE_ENTRYPOINT_INCLUDE_DIR "{{ cmake_var("CMAKE_CURRENT_SOURCE_DIR") }}/{{ entrypoint_out_dir }}")
