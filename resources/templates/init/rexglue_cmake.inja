# Configure a rexglue target with SDK libraries and platform settings.
# Call after add_executable() in your CMakeLists.txt.
# Usage: rexglue_setup_target(<target>)
macro(rexglue_setup_target target_name)
    target_sources({{ cmake_var("target_name") }} PRIVATE {{ cmake_var("REXGLUE_ENTRYPOINT_GENERATED_SOURCES") }})
    target_include_directories({{ cmake_var("target_name") }} PRIVATE
        {{ cmake_var("CMAKE_CURRENT_SOURCE_DIR") }}
        {{ cmake_var("CMAKE_CURRENT_SOURCE_DIR") }}/src
        {{ cmake_var("REXGLUE_ENTRYPOINT_INCLUDE_DIR") }}
