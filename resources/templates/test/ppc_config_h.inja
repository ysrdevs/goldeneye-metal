// Test code base address (matches -Ttext=0x82010000 linker option)
#define REX_IMAGE_BASE 0x{{ image_base }}ull
#define REX_IMAGE_SIZE 0x{{ image_size }}ull
#define REX_CODE_BASE 0x{{ code_base }}ull
#define REX_CODE_SIZE 0x{{ code_size }}ull
#define REX_THUNK_RESERVE_SIZE 0x10000ull

